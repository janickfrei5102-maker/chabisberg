<%- include('partials/header', { title: 'Karte' }) %>

<div id="map"></div>

<link rel="stylesheet" href="https://unpkg.com/leaflet@1.9.4/dist/leaflet.css">
<script src="https://unpkg.com/leaflet@1.9.4/dist/leaflet.js"></script>
<script>
  (function () {
    var CENTER = [47.510679, 8.219608];
    var DEFAULT_ZOOM = 16;

    var map = L.map('map').setView(CENTER, DEFAULT_ZOOM);

    L.tileLayer('https://{s}.tile.openstreetmap.org/{z}/{x}/{y}.png', {
      attribution:
        '&copy; <a href="https://www.openstreetmap.org/copyright">OpenStreetMap</a> contributors',
      maxZoom: 19,
    }).addTo(map);

    var TYPE_ICON = { Erwachsener: '👤', Kind: '🧒', Katze: '🐱', Hund: '🐶' };

    fetch('/api/addresses')
      .then(function (r) {
        if (!r.ok) throw new Error('API ' + r.status);
        return r.json();
      })
      .then(function (addresses) {
        addresses.forEach(function (addr) {
          if (addr.lat == null || addr.lng == null) return;
          L.marker([addr.lat, addr.lng])
            .addTo(map)
            .bindPopup(buildPopup(addr), { maxWidth: 340, minWidth: 260 });
        });
      })
      .catch(function (err) {
        console.error('Karte: Adressen konnten nicht geladen werden', err);
      });

    function buildPopup(addr) {
      var lines = [];

      var name = addr.display_name || (addr.street + ' ' + addr.house_number);
      lines.push(
        '<div style="display:flex;align-items:baseline;justify-content:space-between;gap:8px">' +
          '<strong>' + esc(name) + '</strong>' +
          '<a href="/addresses/' + addr.id + '" style="font-size:0.78em;white-space:nowrap;color:#2c5f2e">Details →</a>' +
          '</div>'
      );
      lines.push(
        '<span style="color:#666;font-size:0.85em">' +
          esc(addr.street + ' ' + addr.house_number) + ', ' +
          esc(addr.postal_code + ' ' + addr.city) +
          '</span>'
      );

      if (addr.residents && addr.residents.length > 0) {
        lines.push('<hr style="margin:6px 0">');
        addr.residents.forEach(function (r) {
          var icon = TYPE_ICON[r.type] || '👤';
          var img = r.picture
            ? '<img src="/thumbs/residents/' + esc(r.picture) + '" style="width:40px;height:40px;border-radius:50%;object-fit:cover;flex-shrink:0">'
            : '<span style="width:40px;height:40px;border-radius:50%;background:#e8f5e9;display:flex;align-items:center;justify-content:center;font-size:1.3em;flex-shrink:0">' + icon + '</span>';

          var claim = r.claim
            ? '<span style="color:#888;font-size:0.78em;display:block;line-height:1.3">' + esc(r.claim) + '</span>'
            : '';

          var birthday = '';
          if (r.showbirthday && r.birthday) {
            var bd = new Date(r.birthday);
            var today = new Date();
            var age = today.getFullYear() - bd.getFullYear() -
              (today < new Date(today.getFullYear(), bd.getMonth(), bd.getDate()) ? 1 : 0);
            birthday = '<span style="color:#888;font-size:0.78em;display:block">🎂 ' +
              esc(bd.toLocaleDateString('de-CH', { day: 'numeric', month: 'long' })) +
              ' (' + age + ' J.)</span>';
          }

          lines.push(
            '<div style="margin:5px 0;display:flex;align-items:flex-start;gap:10px">' +
              img + '<div><span style="font-weight:500">' + esc(r.display_name) + '</span>' +
              claim + birthday + '</div></div>'
          );
        });
      }

      lines.push(
        '<div style="margin-top:8px;text-align:right">' +
          '<a href="/addresses/' + addr.id + '" style="font-size:0.82em;color:#2c5f2e">Alle Details + Kontakte speichern →</a>' +
          '</div>'
      );

      return lines.join('');
    }

    function esc(str) {
      return String(str)
        .replace(/&/g, '&amp;').replace(/</g, '&lt;')
        .replace(/>/g, '&gt;').replace(/"/g, '&quot;');
    }
  })();
</script>

<%- include('partials/footer') %>
