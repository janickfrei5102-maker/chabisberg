<%- include('partials/header', { title: 'Karte' }) %>

<div style="max-width:800px;margin:0 auto">
  <div id="map" style="height:460px"></div>
</div>

<link rel="stylesheet" href="https://unpkg.com/leaflet@1.9.4/dist/leaflet.css">
<script src="https://unpkg.com/leaflet@1.9.4/dist/leaflet.js"></script>
<script>
  (function () {
    var CENTER = [47.510679, 8.219608];
    var DEFAULT_ZOOM = 16;

    var map = L.map('map').setView(CENTER, DEFAULT_ZOOM);

    L.tileLayer('https://{s}.tile.openstreetmap.org/{z}/{x}/{y}.png', {
      attribution: '&copy; <a href="https://www.openstreetmap.org/copyright">OpenStreetMap</a> contributors',
      maxZoom: 19,
    }).addTo(map);

    var TYPE_ICON = { Erwachsener: '👤', Kind: '🧒', Katze: '🐱', Hund: '🐶' };

    fetch('/api/addresses')
      .then(function (r) { if (!r.ok) throw new Error('API ' + r.status); return r.json(); })
      .then(function (addresses) {
        addresses.forEach(function (addr) {
          if (addr.lat == null || addr.lng == null) return;
          L.marker([addr.lat, addr.lng])
            .addTo(map)
            .bindPopup(buildPopup(addr), { maxWidth: 340, minWidth: 260 });
        });
      })
      .catch(function (err) { console.error('Karte: Adressen konnten nicht geladen werden', err); });

    function buildPopup(addr) {
      var lines = [];
      var name = addr.display_name || (addr.street + ' ' + addr.house_number);
      lines.push(
        '<div style="display:flex;align-items:baseline;justify-content:space-between;gap:8px">' +
          '<strong>' + esc(name) + '</strong>' +
          '<a href="/addresses/' + addr.id + '" style="font-size:0.78em;white-space:nowrap;color:#2c5f2e">Details →</a>' +
        '</div>'
      );
      lines.push('<span style="color:#666;font-size:0.85em">' + esc(addr.street + ' ' + addr.house_number) + ', ' + esc(addr.postal_code + ' ' + addr.city) + '</span>');
      if (addr.residents && addr.residents.length > 0) {
        lines.push('<hr style="margin:6px 0">');
        addr.residents.forEach(function (r) {
          var icon = TYPE_ICON[r.type] || '👤';
          var img = r.picture
            ? '<img src="/thumbs/residents/' + esc(r.picture) + '" style="width:40px;height:40px;border-radius:50%;object-fit:cover;flex-shrink:0">'
            : '<span style="width:40px;height:40px;border-radius:50%;background:#e8f5e9;display:flex;align-items:center;justify-content:center;font-size:1.3em;flex-shrink:0">' + icon + '</span>';
          lines.push('<div style="margin:5px 0;display:flex;align-items:center;gap:10px">' + img + '<span style="font-weight:500">' + esc(r.display_name) + '</span></div>');
        });
      }
      lines.push('<div style="margin-top:8px;text-align:right"><a href="/addresses/' + addr.id + '" style="font-size:0.82em;color:#2c5f2e">Alle Details + Kontakte speichern →</a></div>');
      return lines.join('');
    }

    function esc(str) {
      return String(str).replace(/&/g,'&amp;').replace(/</g,'&lt;').replace(/>/g,'&gt;').replace(/"/g,'&quot;');
    }
  })();
</script>

<!-- Address table -->
<h2 style="margin-top:2rem">Alle Adressen</h2>
<table class="addr-table">
  <thead>
    <tr>
      <th>Adresse</th>
      <th>Bewohner</th>
    </tr>
  </thead>
  <tbody>
    <% addresses.forEach(function(addr) { %>
    <tr>
      <td>
        <a href="/addresses/<%= addr.id %>" class="addr-table-link">
          <strong><%= addr.display_name || (addr.street + ' ' + addr.house_number) %></strong>
        </a>
        <div style="font-size:0.85em;color:#666;margin-top:2px">
          <%= addr.street %> <%= addr.house_number %>
        </div>
      </td>
      <td>
        <div class="addr-table-residents">
          <% (addr.residents || []).forEach(function(r) { %>
          <div class="addr-table-resident">
            <% if (r.picture) { %>
              <img src="/thumbs/residents/<%= r.picture %>" alt="<%= r.display_name %>" class="addr-table-avatar">
            <% } else { %>
              <span class="addr-table-avatar addr-table-avatar-placeholder">
                <% if (r.type === 'Katze') { %>🐱<% } else if (r.type === 'Hund') { %>🐶<% } else if (r.type === 'Kind') { %>🧒<% } else { %>👤<% } %>
              </span>
            <% } %>
            <span class="addr-table-rname"><%= r.display_name %></span>
          </div>
          <% }); %>
          <% if (!addr.residents || !addr.residents.length) { %>
            <span style="color:#bbb;font-size:0.85em">—</span>
          <% } %>
        </div>
      </td>
    </tr>
    <% }); %>
  </tbody>
</table>

<style>
  .addr-table {
    width: 100%;
    border-collapse: collapse;
    margin-top: 0.75rem;
    font-size: 0.95rem;
  }
  .addr-table th {
    text-align: left;
    padding: 0.5rem 0.75rem;
    background: #f4f4f4;
    border-bottom: 2px solid #ddd;
    font-weight: 600;
  }
  .addr-table td {
    padding: 0.6rem 0.75rem;
    border-bottom: 1px solid #eee;
    vertical-align: top;
  }
  .addr-table tr:hover td { background: #fafff8; }
  .addr-table-link { color: #2c5f2e; text-decoration: none; }
  .addr-table-link:hover { text-decoration: underline; }
  .addr-table-residents { display: flex; flex-wrap: wrap; gap: 0.5rem; }
  .addr-table-resident { display: flex; align-items: center; gap: 6px; }
  .addr-table-avatar {
    width: 32px; height: 32px; border-radius: 50%; object-fit: cover; flex-shrink: 0;
  }
  .addr-table-avatar-placeholder {
    display: flex; align-items: center; justify-content: center;
    background: #e8f5e9; font-size: 1em;
  }
  .addr-table-rname { font-size: 0.88rem; }
</style>

<%- include('partials/footer') %>
