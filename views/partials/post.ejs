<article class="post-card" id="post-<%= post.id %>">
  <header class="post-header">
    <div class="post-meta">
      <span>
        <strong><%= post.author_display_name || post.author_username %></strong>
        <% if (post.author_address_id && post.author_address_name) { %>
          · <a href="/addresses/<%= post.author_address_id %>" class="post-address-link"><%= post.author_address_name %></a>
        <% } %>
      </span>
      <time datetime="<%= post.created_at %>">
        <%= new Date(post.created_at).toLocaleDateString('de-CH', { day: 'numeric', month: 'long', year: 'numeric', hour: '2-digit', minute: '2-digit' }) %>
      </time>
    </div>
    <% if (user && (user.id === post.author_user_id || user.role === 'admin')) { %>
      <form action="/posts/<%= post.id %>/delete" method="POST" class="post-delete-form"
            onsubmit="return confirm('Post wirklich löschen?')">
        <input type="hidden" name="_csrf" value="<%= csrfToken %>">
        <button type="submit" class="btn-danger btn-sm">Löschen</button>
      </form>
    <% } %>
  </header>

  <% if (post.title) { %><h3 class="post-title"><%= post.title %></h3><% } %>

  <div class="post-body"><%= post.body %></div>

  <% if (post.hyperlink) { %>
    <p class="post-link">
      🔗 <a href="<%= post.hyperlink %>" target="_blank" rel="noopener noreferrer">
        <%= post.hyperlink.length > 60 ? post.hyperlink.slice(0, 60) + '…' : post.hyperlink %>
      </a>
    </p>
  <% } %>

  <%
    var images = post.attachments.filter(function(a) { return a.is_image; });
    var files  = post.attachments.filter(function(a) { return !a.is_image; });
  %>

  <% if (images.length > 0) { %>
    <div class="image-gallery">
      <% images.forEach(function(img) { %>
        <button class="gallery-thumb-btn" onclick="openLightbox('<%= img.file_url %>')"
                aria-label="<%= img.filename %> vergrössern">
          <img src="<%= img.thumb_url %>" alt="<%= img.filename %>" loading="lazy">
        </button>
      <% }); %>
    </div>
  <% } %>

  <% if (files.length > 0) { %>
    <ul class="file-list">
      <% files.forEach(function(f) { %>
        <li>
          📎 <a href="<%= f.file_url %>" download="<%= f.filename %>"><%= f.filename %></a>
          <span class="file-size">(<%= (f.size_bytes / 1024 / 1024).toFixed(1) %> MB)</span>
        </li>
      <% }); %>
    </ul>
  <% } %>
  <!-- Comments -->
  <div class="comments-section">
    <% if (post.comments && post.comments.length > 0) { %>
      <div class="comments-list">
        <% post.comments.forEach(function(c) { %>
          <div class="comment">
            <div class="comment-meta">
              <strong><%= c.author_display_name || c.author_username %></strong>
              <time class="comment-time" datetime="<%= c.created_at %>">
                <%= new Date(c.created_at).toLocaleDateString('de-CH', { day: 'numeric', month: 'short', year: 'numeric', hour: '2-digit', minute: '2-digit' }) %>
              </time>
              <% if (user && (user.id === c.author_user_id || user.role === 'admin')) { %>
                <form action="/posts/<%= post.id %>/comments/<%= c.id %>/delete" method="POST" class="comment-delete-form">
                  <input type="hidden" name="_csrf" value="<%= csrfToken %>">
                  <button type="submit" class="btn-danger btn-xs" onclick="return confirm('Kommentar löschen?')">×</button>
                </form>
              <% } %>
            </div>
            <div class="comment-body"><%= c.body %></div>
          </div>
        <% }); %>
      </div>
    <% } %>

    <form action="/posts/<%= post.id %>/comments" method="POST" class="comment-form">
      <input type="hidden" name="_csrf" value="<%= csrfToken %>">
      <textarea name="body" rows="2" placeholder="Kommentar schreiben…" required></textarea>
      <button type="submit">Kommentieren</button>
    </form>
  </div>
</article>
