<!DOCTYPE html>
<html lang="de">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title><%= typeof title !== 'undefined' ? title + ' – Chabisberg' : 'Chabisberg' %></title>
  <link rel="icon" type="image/svg+xml" href="/favicon.svg">
  <link rel="stylesheet" href="/css/style.css">
</head>
<body>
<nav>
  <a href="/" class="nav-brand">Chabisberg</a>
  <% if (user) { %>
    <a href="/" class="nav-link<%= currentPath === '/' ? ' nav-active' : '' %>">News</a>
    <a href="/map" class="nav-link<%= currentPath === '/map' ? ' nav-active' : '' %>">Karte</a>
    <a href="/profile" class="nav-link<%= (currentPath || '').startsWith('/profile') ? ' nav-active' : '' %>">Mein Profil</a>
    <% if (user.role === 'admin') { %>
      <a href="/admin" class="nav-link<%= (currentPath || '').startsWith('/admin') ? ' nav-active' : '' %>">Admin</a>
    <% } %>
    <span class="nav-user"><%= user.username %></span>
    <form action="/auth/logout" method="POST" style="display:inline;margin:0">
      <input type="hidden" name="_csrf" value="<%= csrfToken %>">
      <button type="submit" class="nav-logout">Abmelden</button>
    </form>
  <% } %>
</nav>
<main>
