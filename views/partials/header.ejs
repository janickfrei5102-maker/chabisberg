<!DOCTYPE html>
<html lang="de">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title><%= typeof title !== 'undefined' ? title + ' – Chabisberg' : 'Chabisberg' %></title>
  <link rel="icon" type="image/svg+xml" href="/favicon.svg">
  <link rel="stylesheet" href="/css/style.css">
</head>
<body>
<nav>
  <a href="/" class="nav-brand">Chabisberg</a>
  <% if (user) { %>
    <button class="nav-burger" id="nav-burger" aria-label="Menü öffnen" aria-expanded="false" aria-controls="nav-menu">
      <span></span><span></span><span></span>
    </button>
    <div class="nav-menu" id="nav-menu">
      <a href="/" class="nav-link<%= currentPath === '/' ? ' nav-active' : '' %>">Beiträge</a>
      <a href="/map" class="nav-link<%= currentPath === '/map' ? ' nav-active' : '' %>">Quartier</a>
      <a href="/profile" class="nav-link<%= (currentPath || '').startsWith('/profile') ? ' nav-active' : '' %>">Mein Profil</a>
      <% if (user.role === 'admin') { %>
        <a href="/admin" class="nav-link<%= (currentPath || '').startsWith('/admin') ? ' nav-active' : '' %>">Admin</a>
      <% } %>
      <span class="nav-user"><%= user.display_name || user.username %></span>
      <form action="/auth/logout" method="POST" style="margin:0">
        <input type="hidden" name="_csrf" value="<%= csrfToken %>">
        <button type="submit" class="nav-logout">Abmelden</button>
      </form>
    </div>
  <% } %>
</nav>
<script>
  (function() {
    var btn = document.getElementById('nav-burger');
    var menu = document.getElementById('nav-menu');
    if (!btn) return;
    btn.addEventListener('click', function() {
      var open = menu.classList.toggle('nav-menu-open');
      btn.setAttribute('aria-expanded', open);
    });
    // Close on outside click
    document.addEventListener('click', function(e) {
      if (!btn.contains(e.target) && !menu.contains(e.target)) {
        menu.classList.remove('nav-menu-open');
        btn.setAttribute('aria-expanded', 'false');
      }
    });
  })();
</script>
<main>
