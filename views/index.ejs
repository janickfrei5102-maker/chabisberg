<%- include('partials/header', { title: 'Startseite' }) %>

<section id="news">
  <h2>News</h2>

  <!-- Post form — multipart because of file uploads, CSRF token in query param -->
  <details class="post-form-wrapper" id="post-form-toggle">
    <summary class="btn" style="cursor:pointer;list-style:none;display:inline-block;margin-bottom:1rem">
      + Beitrag schreiben
    </summary>
    <form action="/posts?_csrf=<%= encodeURIComponent(csrfToken) %>"
          method="POST" enctype="multipart/form-data" class="post-form">

      <label>
        Titel <small>(optional)</small>
        <input type="text" name="title" placeholder="Kurzer Titel…" maxlength="200">
      </label>

      <label>
        Beitrag <span style="color:#c00">*</span>
        <textarea name="body" rows="5" placeholder="Was gibt es Neues im Quartier?" required></textarea>
      </label>

      <label>
        Link <small>(optional)</small>
        <input type="url" name="hyperlink" placeholder="https://…">
      </label>

      <label>
        Anhänge <small>(optional, max <%= typeof MAX_ATTACHMENT_MB !== 'undefined' ? MAX_ATTACHMENT_MB : 90 %> MB pro Datei)</small>
        <input type="file" name="attachments" multiple>
      </label>

      <div style="margin-top:0.75rem">
        <button type="submit">Veröffentlichen</button>
      </div>
    </form>
  </details>

  <!-- Post list -->
  <% if (postList && postList.length > 0) { %>
    <div class="post-list">
      <% postList.forEach(function(post) { %>
        <%- include('partials/post', { post: post }) %>
      <% }); %>
    </div>

    <!-- Pagination -->
    <% var totalPages = Math.ceil(total / pageSize); %>
    <% if (totalPages > 1) { %>
      <nav class="pagination">
        <% if (page > 1) { %><a href="/?page=<%= page - 1 %>#news">← Neuer</a><% } %>
        <span style="padding:0.3rem 0.5rem;color:#666">Seite <%= page %> / <%= totalPages %></span>
        <% if (page < totalPages) { %><a href="/?page=<%= page + 1 %>#news">Älter →</a><% } %>
      </nav>
    <% } %>
  <% } else { %>
    <p style="color:#999;margin-top:1rem">Noch keine Beiträge. Schreib den ersten!</p>
  <% } %>
</section>

<!-- Lightbox overlay -->
<div id="lightbox" class="lightbox-overlay" style="display:none" onclick="closeLightbox()">
  <div class="lightbox-inner" onclick="event.stopPropagation()">
    <button class="lightbox-close" onclick="closeLightbox()">✕</button>
    <img id="lightbox-img" src="" alt="">
  </div>
</div>

<script>
  function openLightbox(src) {
    document.getElementById('lightbox-img').src = src;
    document.getElementById('lightbox').style.display = 'flex';
    document.body.style.overflow = 'hidden';
  }
  function closeLightbox() {
    document.getElementById('lightbox').style.display = 'none';
    document.body.style.overflow = '';
    document.getElementById('lightbox-img').src = '';
  }
  document.addEventListener('keydown', function(e) {
    if (e.key === 'Escape') closeLightbox();
  });
</script>

<section id="karte">
  <h2>Karte</h2>
  <div id="map"></div>
</section>

<link rel="stylesheet" href="https://unpkg.com/leaflet@1.9.4/dist/leaflet.css">
<script src="https://unpkg.com/leaflet@1.9.4/dist/leaflet.js"></script>
<script>
  (function () {
    // Default center: Quartier Chabisberg
    var CENTER = [47.510679, 8.219608];
    var DEFAULT_ZOOM = 17;

    var map = L.map('map').setView(CENTER, DEFAULT_ZOOM);

    L.tileLayer('https://tiles.stadiamaps.com/tiles/osm_bright/{z}/{x}/{y}{r}.png', {
      attribution:
        '&copy; <a href="https://stadiamaps.com/">Stadia Maps</a> ' +
        '&copy; <a href="https://openmaptiles.org/">OpenMapTiles</a> ' +
        '&copy; <a href="https://www.openstreetmap.org/copyright">OpenStreetMap</a> contributors',
      maxZoom: 20,
    }).addTo(map);

    // Type → emoji for residents without a profile picture
    var TYPE_ICON = { Erwachsener: '👤', Kind: '🧒', Katze: '🐱', Hund: '🐶' };

    fetch('/api/addresses')
      .then(function (r) {
        if (!r.ok) throw new Error('API ' + r.status);
        return r.json();
      })
      .then(function (addresses) {
        addresses.forEach(function (addr) {
          if (addr.lat == null || addr.lng == null) return;

          var popup = buildPopup(addr);
          L.marker([addr.lat, addr.lng])
            .addTo(map)
            .bindPopup(popup, { maxWidth: 340, minWidth: 260 });
        });
      })
      .catch(function (err) {
        console.error('Karte: Adressen konnten nicht geladen werden', err);
      });

    function buildPopup(addr) {
      var lines = [];

      // Header: display name + full address + link to detail view
      var name = addr.display_name || (addr.street + ' ' + addr.house_number);
      lines.push(
        '<div style="display:flex;align-items:baseline;justify-content:space-between;gap:8px">' +
          '<strong>' + esc(name) + '</strong>' +
          '<a href="/addresses/' + addr.id + '" style="font-size:0.78em;white-space:nowrap;color:#2c5f2e">Details →</a>' +
          '</div>'
      );
      lines.push(
        '<span style="color:#666;font-size:0.85em">' +
          esc(addr.street + ' ' + addr.house_number) +
          ', ' +
          esc(addr.postal_code + ' ' + addr.city) +
          '</span>'
      );

      // Residents list
      if (addr.residents && addr.residents.length > 0) {
        lines.push('<hr style="margin:6px 0">');
        addr.residents.forEach(function (r) {
          var icon = TYPE_ICON[r.type] || '👤';
          var img = r.picture
            ? '<img src="/thumbs/residents/' +
              esc(r.picture) +
              '" style="width:40px;height:40px;border-radius:50%;object-fit:cover;flex-shrink:0">'
            : '<span style="width:40px;height:40px;border-radius:50%;background:#e8f5e9;display:flex;align-items:center;justify-content:center;font-size:1.3em;flex-shrink:0">' +
              icon +
              '</span>';

          var claim = r.claim
            ? '<span style="color:#888;font-size:0.78em;display:block;line-height:1.3">' + esc(r.claim) + '</span>'
            : '';

          // Birthday: only shown when showbirthday is true
          var birthday = '';
          if (r.showbirthday && r.birthday) {
            var bd = new Date(r.birthday);
            var today = new Date();
            var age = today.getFullYear() - bd.getFullYear() -
              (today < new Date(today.getFullYear(), bd.getMonth(), bd.getDate()) ? 1 : 0);
            var bdStr = bd.toLocaleDateString('de-CH', { day: 'numeric', month: 'long' });
            birthday = '<span style="color:#888;font-size:0.78em;display:block">🎂 ' + esc(bdStr) + ' (' + age + ' J.)</span>';
          }

          lines.push(
            '<div style="margin:5px 0;display:flex;align-items:flex-start;gap:10px">' +
              img +
              '<div><span style="font-weight:500">' + esc(r.display_name) + '</span>' +
              claim + birthday +
              '</div></div>'
          );
        });
      }

      // Footer link to full detail
      lines.push(
        '<div style="margin-top:8px;text-align:right">' +
          '<a href="/addresses/' + addr.id + '" style="font-size:0.82em;color:#2c5f2e">Alle Details + Kontakte speichern →</a>' +
          '</div>'
      );

      return lines.join('');
    }

    function esc(str) {
      return String(str)
        .replace(/&/g, '&amp;')
        .replace(/</g, '&lt;')
        .replace(/>/g, '&gt;')
        .replace(/"/g, '&quot;');
    }
  })();
</script>

<%- include('partials/footer') %>
