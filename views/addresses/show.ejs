<%- include('../partials/header', { title: address.display_name || address.street + ' ' + address.house_number }) %>

<a href="/map" style="font-size:0.85rem;color:#2c5f2e;text-decoration:none">← Zurück zur Karte</a>

<div class="address-detail">
  <div class="address-detail-header">
    <h1><%= address.display_name || (address.street + ' ' + address.house_number) %></h1>
    <p class="address-detail-sub">
      <%= address.street %> <%= address.house_number %>,
      <%= address.postal_code %> <%= address.city %>
    </p>
  </div>

  <% if (address.residents && address.residents.length > 0) { %>
    <h2 style="margin-top:2rem">Bewohner</h2>
    <div class="residents-grid">
      <% address.residents.forEach(function(r) { %>
        <div class="resident-card resident-card-detail">

          <div class="resident-avatar">
            <% if (r.picture) { %>
              <button class="avatar-lightbox-btn" onclick="openLightbox('/addresses/<%= address.id %>/residents/<%= r.id %>/photo')" title="<%= r.display_name %> vergrössern" aria-label="Foto vergrössern">
                <img src="/thumbs/residents/<%= r.picture %>" alt="<%= r.display_name %>">
              </button>
            <% } else { %>
              <div class="avatar-placeholder">
                <% var icons = { Erwachsener: '👤', Kind: '🧒', Katze: '🐱', Hund: '🐶' }; %>
                <%= icons[r.type] || '👤' %>
              </div>
            <% } %>
          </div>

          <div class="resident-info" style="flex:1">
            <strong><%= r.display_name %></strong>
            <span class="resident-type"><%= r.type %></span>

            <% if (r.claim) { %>
              <p class="resident-claim"><%= r.claim %></p>
            <% } %>

            <% if (r.showbirthday && r.birthday) { %>
              <%
                var bd = new Date(r.birthday);
                var today = new Date();
                var age = today.getFullYear() - bd.getFullYear() -
                  (today < new Date(today.getFullYear(), bd.getMonth(), bd.getDate()) ? 1 : 0);
                var bdFormatted = bd.toLocaleDateString('de-CH', { day: 'numeric', month: 'long', year: 'numeric' });
              %>
              <p class="resident-birthday">🎂 <%= bdFormatted %> (<%= age %> J.)</p>
            <% } %>

            <% if (r.phone) { %>
              <p class="resident-phone">
                📞 <a href="tel:<%= r.phone %>"><%= r.phone %></a>
              </p>
            <% } %>

            <% if (r.type === 'Erwachsener') { %>
            <div style="margin-top:0.75rem">
              <a href="/addresses/<%= address.id %>/residents/<%= r.id %>/vcard"
                 class="btn btn-vcard"
                 title="Kontakt speichern">
                ⬇ Kontakt speichern
              </a>
            </div>
            <% } %>
          </div>
        </div>
      <% }); %>
    </div>
  <% } else { %>
    <p style="color:#999;margin-top:2rem">Keine Bewohner eingetragen.</p>
  <% } %>
</div>

<% if (address.lat != null && address.lng != null) { %>
<div style="margin-top:2.5rem">
  <h2 style="margin-bottom:0.75rem">Standort</h2>
  <div id="addr-map" style="height:260px;border-radius:6px;border:1px solid #ddd"></div>
</div>

<link rel="stylesheet" href="https://unpkg.com/leaflet@1.9.4/dist/leaflet.css">
<script src="https://unpkg.com/leaflet@1.9.4/dist/leaflet.js"></script>
<script>
  (function () {
    var lat = <%= address.lat %>;
    var lng = <%= address.lng %>;
    var map = L.map('addr-map', {
      zoomControl: true,
      scrollWheelZoom: false,
      doubleClickZoom: false,
      boxZoom: false,
      keyboard: false,
    }).setView([lat, lng], 17);

    L.tileLayer('https://{s}.tile.openstreetmap.org/{z}/{x}/{y}.png', {
      attribution: '&copy; <a href="https://www.openstreetmap.org/copyright">OpenStreetMap</a> contributors',
      maxZoom: 19,
    }).addTo(map);

    // Marker without popup — decorative only, shows location but has no click action
    L.marker([lat, lng]).addTo(map);
  })();
</script>
<% } %>

<!-- Lightbox -->
<div id="lightbox" class="lightbox-overlay" style="display:none" onclick="closeLightbox()">
  <div class="lightbox-inner" onclick="event.stopPropagation()">
    <button class="lightbox-close" onclick="closeLightbox()">✕</button>
    <img id="lightbox-img" src="" alt="">
  </div>
</div>

<style>
  .avatar-lightbox-btn {
    background: none;
    border: none;
    padding: 0;
    cursor: zoom-in;
    display: block;
  }
  .avatar-lightbox-btn img { display: block; }
</style>

<script>
  function openLightbox(src) {
    document.getElementById('lightbox-img').src = src;
    document.getElementById('lightbox').style.display = 'flex';
    document.body.style.overflow = 'hidden';
  }
  function closeLightbox() {
    document.getElementById('lightbox').style.display = 'none';
    document.body.style.overflow = '';
    document.getElementById('lightbox-img').src = '';
  }
  document.addEventListener('keydown', function(e) {
    if (e.key === 'Escape') closeLightbox();
  });
</script>

<%- include('../partials/footer') %>
