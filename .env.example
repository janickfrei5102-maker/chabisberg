# ── App ────────────────────────────────────────────────────────────────────────
PORT=3000
NODE_ENV=production

# Long random string — generate with:
# node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
SESSION_SECRET=changeme

# ── Database & Storage ─────────────────────────────────────────────────────────
DATABASE_PATH=/data/db/chabisberg.sqlite
UPLOAD_DIR=/data/uploads
THUMBNAIL_DIR=/data/thumbnails

# Cloudflare Free plan hard limit is ~100 MB per request.
# 90 MB keeps us safely under that ceiling.
MAX_UPLOAD_SIZE_MB=90

# ── Admin seed ─────────────────────────────────────────────────────────────────
ADMIN_USERNAME=admin
ADMIN_PASSWORD=changeme

# ── Proxy / TLS ────────────────────────────────────────────────────────────────
# Set to "true" when behind Cloudflare Tunnel or any HTTPS-terminating proxy.
# Enables Secure cookie flag and correct client-IP extraction.
TRUST_PROXY=true

# ── Docker volume paths (host side) ───────────────────────────────────────────
# Override to point to Unraid appdata paths, e.g.:
#   DATA_DB_PATH=/mnt/user/appdata/chabisberg/db
DATA_DB_PATH=./data/db
DATA_UPLOADS_PATH=./data/uploads
DATA_THUMBNAILS_PATH=./data/thumbnails

# Port binding on host. Default: localhost only (Cloudflare Tunnel handles external access).
# Change to 0.0.0.0:3000 only if you need direct host access without a tunnel.
HOST_PORT=127.0.0.1:3000

# ── Cloudflare Tunnel ──────────────────────────────────────────────────────────
# Token from: Cloudflare Zero Trust dashboard → Networks → Tunnels
#             → your tunnel → Configure → Token
CLOUDFLARE_TUNNEL_TOKEN=changeme
